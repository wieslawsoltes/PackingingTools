# Use the Lunet default templates for docs navigation, layout, and API rendering.
extend "lunet-io/templates"

template_theme_default_mode = "system"

site_project_baseurl = "https://wieslawsoltes.github.io"
site_project_basepath = environment == "dev" ? "" : "/PackingingTools"
site_project_name = "PackagingTools"
site_project_description = "Cross-platform .NET packaging stack for Windows, macOS, and Linux installers with shared project models, CLI automation, SDK embedding, and generated API reference."
site_project_logo_path = "/images/logo.svg"
site_project_social_banner_path = "/images/logo.svg"
site_project_package_id = "PackagingTools"
site_project_github_user = "wieslawsoltes"
site_project_github_repo = "PackingingTools"
site_project_owner_name = "Wieslaw Soltes"
site_project_owner_alias = "wieslawsoltes"
site_project_owner_url = "https://github.com/wieslawsoltes"
site_project_twitter_user = "wieslawsoltes"

site_project_init

# Use the same precompiled template bundle pattern as TreeDataGrid.
with bundle "lite"

    bootstrap = resource "npm:bootstrap" "5.3.8"
    bootstrap_icons = resource "npm:bootstrap-icons" "1.13.1"
    tocbot = resource "npm:tocbot" "4.36.4"
    anchorjs = resource "npm:anchor-js" "5.0.0"
    prismjs = resource "npm:prismjs" "1.30.0"

    css tocbot "/dist/tocbot.css"
    css "/css/prism.css"
    css "/css/template-main.css"
    css "/css/site-overrides.css"

    js "/modules/menus/lunet-menu-async.js"
    js "/modules/api/dotnet/lunet-api-dotnet-ui.js"
    js bootstrap "/dist/js/bootstrap.bundle.min.js"
    js anchorjs "/anchor.min.js"
    js tocbot "/dist/tocbot.min.js"
    js prismjs "/prism.js"
    js prismjs "/plugins/autoloader/prism-autoloader.min.js"
    js prismjs "/plugins/toolbar/prism-toolbar.min.js"
    js prismjs "/plugins/copy-to-clipboard/prism-copy-to-clipboard.min.js"
    js prismjs "/plugins/show-language/prism-show-language.min.js"
    js "/js/prism-scriban.js"
    js "/js/main.js"

    for path in template_prism_components
        content prismjs "components/" + path "/js/components/"
    end

    content bootstrap_icons "/font/fonts/bootstrap-icons.*" "/fonts/"

    concat = true
    minify = false
end

with attributes
    match "/**/*.md" {
        bundle: "lite"
    }
end

with api.dotnet
    title = "PackagingTools .NET API Reference"
    path = "/api"
    menu_name = "api"
    menu_title = "API Reference"
    config = "Release"
    properties = {
        TargetFramework: "net10.0"
    }
    projects = [
        { name: "PackagingTools.Core", path: "../src/PackagingTools.Core/PackagingTools.Core.csproj" },
        { name: "PackagingTools.Core.Windows", path: "../src/PackagingTools.Core.Windows/PackagingTools.Core.Windows.csproj" },
        { name: "PackagingTools.Core.Mac", path: "../src/PackagingTools.Core.Mac/PackagingTools.Core.Mac.csproj" },
        { name: "PackagingTools.Core.Linux", path: "../src/PackagingTools.Core.Linux/PackagingTools.Core.Linux.csproj" },
        { name: "PackagingTools.Plugins", path: "../src/PackagingTools.Plugins/PackagingTools.Plugins.csproj" },
        { name: "PackagingTools.Sdk", path: "../src/PackagingTools.Sdk/PackagingTools.Sdk.csproj" },
        { name: "PackagingTools.Cli", path: "../src/PackagingTools.Cli/PackagingTools.Cli.csproj" }
    ]
end
